{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "esnext",
    
    // FIX 1: Use modern module resolution
    "moduleResolution": "bundler", // Or "nodenext" for pure Node.js
    
    "target": "esnext",
  
    "outDir": "./dist",
    
    // FIX 2: Explicitly set the root directory so TS knows how to map to outDir
    "rootDir": ".", 
    
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedSideEffectImports": true,
    
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },

  "include": [
    "src/**/*",
    "app.js"
  ]
}