{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "esnext", // or "ESNext" depending on your Node setup
    
    "moduleResolution": "node", 
    
    "target": "esnext",
  
    "outDir": "./dist",
    
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedSideEffectImports": true,
    
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },

  "include": [
    "src/**/*",
    "app.js"
  ]
}