{
  "expo": {
    "name": "auto-hub",
    "slug": "auto-hub",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo_dark.png",
    "scheme": "autohub",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.autohub.autohub"
    },
    "android": {
      "package": "com.autohub.autohub",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/logo_dark.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "85b0c6ca-6305-4522-8c56-0484234a2dfb"
      }
    }
  }
}
